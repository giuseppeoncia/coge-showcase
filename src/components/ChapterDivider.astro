---
interface Props {
  label: string;
  number: string;
  title: string;
}
const { label, number, title } = Astro.props;
---
<div class="divider">
  <div class="rule" aria-hidden="true"></div>
  <p class="chapter-label">{label} {number}</p>
  <h2>{title}</h2>
</div>

<style>
  .divider {
    text-align: center;
    margin-block-end: 48px;
  }
  .rule {
    height: 2px;
    width: 60px;
    margin-inline: auto;
    margin-block-end: 20px;
    background: var(--gradient);
    border-radius: 2px;
  }
  h2 { margin-top: 8px; }
</style>
