---
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
  icon: string;
  titleIt: string;
  titleEn: string;
  bodyIt: string;
  bodyEn: string;
  screenshot: string;
}
const { lang, icon, titleIt, titleEn, bodyIt, bodyEn, screenshot } = Astro.props;
const title = lang === 'it' ? titleIt : titleEn;
const body = lang === 'it' ? bodyIt : bodyEn;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const avif = `${base}/screenshots/${screenshot}.avif`;
const webp = `${base}/screenshots/${screenshot}.webp`;
const alt = title;
---
<article class="feature-card">
  <button
    class="thumb-trigger"
    type="button"
    data-avif={avif}
    data-webp={webp}
    data-caption={alt}
    aria-label={lang === 'it' ? `Ingrandisci screenshot: ${alt}` : `Enlarge screenshot: ${alt}`}
  >
    <picture>
      <source srcset={avif} type="image/avif" />
      <source srcset={webp} type="image/webp" />
      <img src={webp} alt={alt} loading="lazy" decoding="async" width="1440" height="900" />
    </picture>
    <span class="zoom-hint" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        <line x1="11" y1="8" x2="11" y2="14"/>
        <line x1="8" y1="11" x2="14" y2="11"/>
      </svg>
    </span>
  </button>
  <div class="meta">
    <div class="icon" aria-hidden="true">{icon}</div>
    <h3>{title}</h3>
    <p>{body}</p>
  </div>
</article>

<style>
  .feature-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(99, 102, 241, 0.3);
  }
  .thumb-trigger {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: var(--hover-tint);
    cursor: zoom-in;
    overflow: hidden;
  }
  .thumb-trigger:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: -2px;
  }
  picture { display: block; }
  img { width: 100%; height: auto; aspect-ratio: 16 / 10; object-fit: cover; display: block; transition: transform 0.3s ease; }
  .feature-card:hover .thumb-trigger img { transform: scale(1.02); }

  .zoom-hint {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: rgba(15, 23, 42, 0.7);
    color: #ffffff;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }
  .feature-card:hover .zoom-hint,
  .thumb-trigger:focus-visible .zoom-hint { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .feature-card:hover .thumb-trigger img { transform: none; }
    img, .zoom-hint { transition: none; }
  }
  .meta { padding: 20px 24px 24px; }
  .icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--hover-tint);
    display: grid;
    place-items: center;
    margin-bottom: 12px;
    font-size: 18px;
  }
  h3 { margin: 0 0 8px; font-size: 1.1rem; }
  p { margin: 0; color: var(--text-muted); font-size: 14px; line-height: 1.55; }
</style>
