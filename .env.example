# Example environment file for screenshot capture + DB anonymization scripts.
# Copy to `.env` and fill in with your local values.
# `.env` is gitignored; never commit a populated copy.

# ---- scripts/capture-screenshots.mjs ----

# CoGe admin login used to authenticate Puppeteer (both Filament + Blade sides).
COGE_EMAIL=your.admin@example.com
COGE_PASSWORD=change-me

# Base URL where the local CoGe instance is reachable. Must match the
# CoGe server's APP_URL exactly, otherwise Filament's lazy-loaded
# x-load JS bundles (TagsInput, KeyValue, etc.) fail to hydrate.
# Typical values: http://localhost:8000, or the HTTPS host assigned by
# a local reverse-proxy / container-host tool.
COGE_BASE_URL=http://localhost:8000

# ---- scripts/anonymize-db.js (via shell + mongosh) ----

# MongoDB admin credentials for the local Docker dev container. Must match
# the MONGO_INITDB_ROOT_USERNAME / PASSWORD baked into your local compose
# setup. Do NOT paste production Mongo credentials here.
MONGO_USER=admin
MONGO_PASSWORD=change-me

# Target database name inside the Mongo container.
MONGO_DB=coge_db

# Consumed by mongosh when you pass it via `--eval "var KEEP_LOGIN_EMAIL='...'"`.
# Not read automatically by the script; the README invocation interpolates it.
KEEP_LOGIN_EMAIL=your.admin@example.com
